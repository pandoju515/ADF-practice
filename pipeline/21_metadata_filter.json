											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "adls_DS_outbound",
									"type": "DatasetReference"
								}
							]
						}
					]
				}
			}
		],
		"variables": {
			"Filedate": {
				"type": "String"
			},
			"Filename": {
				"type": "String"
			}
